# ============================================================
# DroneMedic - All API Keys & Secrets
# ============================================================
# Copy this file to .env and fill in your values.
# ============================================================

# --- AI / LLM ---
ANTHROPIC_API_KEY=your-key-here
OPENAI_API_KEY=your-key-here
OPENAI_BASE_URL=https://chat.kxsb.org/api/v1

# --- Weather ---
OPENWEATHER_API_KEY=your-key-here
WEATHER_ENABLED=false

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your-key-here
GOOGLE_MAPS_SIGNING_SECRET=your-secret-here

# --- Supabase (React frontend) ---
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_API_URL=

# --- Simulation ---
AIRSIM_ENABLED=false

# --- PX4 SITL ---
PX4_ENABLED=false
PX4_CONNECTION=udp://:14540

# --- Unity MCP Server ---
UNITY_MCP_TOKEN=your-token-here
UNITY_MCP_CLOUD_TOKEN=your-token-here
